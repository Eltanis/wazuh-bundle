<!--
  local_rules.xml — Règles custom du bundle Wazuh Monitoring
  Emplacement final : /var/ossec/etc/rules/local_rules.xml -->

<group name="local,intrusion,">

  <!-- Brute force SSH -->
  <rule id="100100" level="10" frequency="8" timeframe="120">
    <if_matched_sid>5760</if_matched_sid>
    <description>Brute force SSH détecté - 8 tentatives en 2 minutes</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

  <!-- Attaques web : SQLi / XSS / LFI -->
  <rule id="100200" level="8">
    <if_group>web|accesslog</if_group>
    <regex>union select|1=1|&lt;script|eval\(|base64_decode|etc/passwd|cmd\.exe</regex>
    <description>Tentative d'attaque web détectée (SQLi/XSS/LFI)</description>
    <mitre>
      <id>T1190</id>
    </mitre>
    <group>web_attack,attack</group>
  </rule>

  <!-- Fichier malveillant détecté par VirusTotal -->
  <rule id="100300" level="15">
    <if_sid>87105</if_sid>
    <description>CRITIQUE: Fichier malveillant détecté par VirusTotal</description>
    <group>virustotal,malware,attack</group>
  </rule>

  <!-- Connexion root hors heures inhabituel -->
  <rule id="100400" level="12">
    <if_sid>5501</if_sid>
    <user>root</user>
    <time>18:00-08:00</time>
    <description>Connexion root hors heures ouvrables</description>
    <group>authentication_success,suspicious</group>
  </rule>

</group>
